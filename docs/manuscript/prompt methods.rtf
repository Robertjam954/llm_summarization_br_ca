\f0\b\fs36 \cf0 \strokec2 3. Pseudocode (Pipeline-Ready)\
\pard\pardeftab720\partightenfactor0

\f3\b0\fs26 \cf0 \
def should_escalate(result):\
    if any(v["value"] == "Indeterminate" for v in result["features"].values()):\
        return True\
\
    high_risk = ["feature_4", "feature_11", "feature_13"]\
    for f in high_risk:\
        if result["features"].get(f, \{\}).get("value") not in ["", "Not reported"]:\
            return True\
\
    if not result.get("feature_9_chronology_preserved", True):\
        return True\
\
    for f, obj in result["features"].items():\
        if obj["value"] not in ["", "Not reported"] and len(obj.get("evidence", "")) < 15:\
            return True\
\
    return False\
\pard\pardeftab720\partightenfactor0

