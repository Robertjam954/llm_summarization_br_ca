def infer_domain_from_filename(path: str):\
    p = Path(path).name.lower()\
    if "path" in p or "surgical" in p:\
        return "pathology"\
    if "rad" in p or "ct" in p or "mri" in p or "mammo" in p:\
        return "radiology"\
