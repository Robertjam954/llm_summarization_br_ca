\f3\b0\fs26 \cf0 \
def extract_element(element_name, element_definition, case_id):\
    query = f"\{element_name\}. \{element_definition\}"\
    docs = retriever.invoke(query)\
\
    context = "\\n\\n".join(\
        [f"[page \{d.metadata.get('page')\}] \{d.page_content\}" for d in docs]\
    )\
\
    msg = prompt.format_messages(\
        element_name=element_name,\
        element_definition=element_definition,\
        context=context\
    )\
\
    resp = llm.invoke(msg).content\
    return resp, docs\
\
\pard\pardeftab720\partightenfactor0

